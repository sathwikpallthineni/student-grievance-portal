<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">


</head>
<body>
    <div class="main">
    <div class="second-main">

      <% if(success && success.length > 0) { %>
<div class="alert alert-success responsive-alert flash-message" role="alert">
  <span><%= success %></span>
  <button class="flash-close">&times;</button>
</div>
<% } %>

<% if(failure && failure.length > 0) { %>
<div class="alert alert-danger responsive-alert flash-message" role="alert">
  <span><%= failure %></span>
  <button class="flash-close">&times;</button>
</div>
<% } %>
 <% if(path === "/authority" || path === "/authority/") {%>
        <div class="mobile-nav">
            <div class="heading">
                <h3>Grievance Portal</h3>
            </div>
            <div class="profile">
                <div class="profile-pic"  onclick="toggleProfile()">
                    <i class="fa-regular fa-user"></i>
                </div>
            </div>
        </div>
        <%}%>
        <% if(path === "/authority" || path === "/authority/") {%>
        <div class="nav">
            <div class="heading">
                <h3>Smart Grievance Portal</h3>
            </div>
            <div class="profile">
                <div class="username">
                    <% if(authority) {%>
                        <h3><%=authority.username%></h3>
                    <% } %>
                </div>
                <div class="profile-pic">
                    <i class="fa-regular fa-user"></i>
                </div>
                <div class="logout">
                    <a class="logout-icon"><i class="fa-solid fa-right-from-bracket"></i></a>
                </div>
            </div>
            
        </div>
        <hr>
        <%}%>
        
        <div class="contain">
            <%- body %>
        </div>
    </div>
     <div class="logout-overlay"></div>
    <div class="logout-warning">
    <div class="logout-header">
        <h3>Confirm Logout</h3>
        <div class="logout-cancelbtn">
            <i class="fa-solid fa-xmark"></i>
        </div>
    </div>

    <p class="logout-text">
        Are you sure you want to log out of your account?
    </p>

    <form class="logout-form" method="post" action="/user/logout">
        <button class="logout-button">Logout</button>
    </form>
</div>
<div class="profile-popup" id="profilePopup">

  <div class="profile-popup-card">

    <h3>Profile</h3>

    <p class="profile-name">
        <% if(authority ) {%>
            <%= authority.username %>
        <%}%>
    </p>

    <form method="POST" action="/user/logout">
      <button class="logout-btn">Logout</button>
    </form>

  </div>

</div>
    </div>
    <script src="/script.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
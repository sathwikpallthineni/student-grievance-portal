<% layout("./layouts/boilerpalte.ejs") %>

<body class="new-page">

<div class="container">
  <a href="/user" class="back-link">← Back to Dashboard</a>

  <h1>Raise New Grievance</h1>

  <form action="/user" method="POST" class="card" enctype="multipart/form-data">
    
    <div class="form-group">
      <label for="title">Grievance Title <span>*</span></label>
      <input
      class="input"
        type="text"
        name="title"
        placeholder="Enter a brief title for your grievance"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description <span>*</span></label>
      <textarea
      class="textarea"
        name="description"
        rows="5"
        maxlength="300"
        placeholder="Describe the issue in detail..."
        required
      ></textarea>
    </div>
    <div class="form-group">
      <label for="attachments">Add Attachments <span>*</span></label>
      <input type="file" name="attachments">
    </div>
    
    <div class="form-group">
      <label for="category">Category <span>*</span></label>
      <select name="category" class="select" required>
        <option value="">Select a category</option>
        <option value="academic">Academic</option>
        <option value="hostel">Hostel</option>
        <option value="transport">Transport</option>
        <option value="administration">Administration</option>
        <option value="infrastructure">Infrastructure</option>
        <option value="other">Other</option>

      </select>
    </div>


    <div class="actions">
      <button type="submit" class="btn-primary">Submit Grievance</button>
      <a href="/user" class="btn-secondary">Cancel</a>
    </div>

  </form>
</div>

</body>

